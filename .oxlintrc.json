{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "vue"],
  "options": {
    "typeAware": true
  },
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    "docs/**",
    ".pglite/**",
    "pnpm-lock.yaml",
    "apps/client/typed-router.d.ts"
  ]
}
