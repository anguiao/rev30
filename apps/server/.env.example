PORT=3000
LOG_LEVEL=info
PGLITE_DATA_DIR=.pglite/dev
# Production DATABASE_URL should point to PostgreSQL 18+.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/rev30
ATTACHMENT_STORAGE_DIR=.attachments/dev
ATTACHMENT_SIGNING_SECRET=change-me-attachment-signing-secret
ATTACHMENT_CLEANUP_INTERVAL_MS=21600000
ATTACHMENT_CLEANUP_RETENTION_MS=604800000
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ATTACHMENT_SECRET=rev30-development-attachment-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
JWT_ATTACHMENT_EXPIRES_IN_SECONDS=86400
AUTH_LOGIN_ATTEMPT_CLEANUP_INTERVAL_MS=21600000
AUTH_LOGIN_ATTEMPT_RETENTION_MS=86400000
AUTH_REFRESH_TOKEN_CLEANUP_INTERVAL_MS=21600000
AUTH_REVOKED_REFRESH_TOKEN_RETENTION_MS=604800000
ICON_SEARCH_INDEX_IDLE_TTL_MS=900000
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BOOTSTRAP_ADMIN_NICKNAME=Administrator
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PHONE=
