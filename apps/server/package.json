{
  "name": "@rev30/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run --testTimeout=15000",
    "db:bootstrap": "tsx src/db/bootstrap.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@hono/node-server": "^2.0.0",
    "@hono/zod-validator": "^0.7.6",
    "@iconify/json": "^2.2.467",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.1",
    "@rev30/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0"
  }
}
