{
  "name": "@rev30/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app.ts",
      "default": "./src/app.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run --pool=threads",
    "db:bootstrap": "tsx src/db/bootstrap.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@file-type/cfbf": "^0.2.2",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@iconify/json": "catalog:",
    "@iconify/tools": "^5.0.12",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.3",
    "@rev30/contracts": "workspace:*",
    "@rev30/rich-text": "workspace:*",
    "@rev30/utils": "workspace:*",
    "bytes": "catalog:",
    "dotenv": "^17.4.2",
    "drizzle-orm": "rc",
    "file-type": "^22.0.1",
    "fzf": "^0.5.2",
    "hono": "catalog:",
    "mime-types": "^3.0.2",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bytes": "catalog:",
    "@types/mime-types": "^3.0.1",
    "drizzle-kit": "rc",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0"
  }
}
