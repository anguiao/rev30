{
  "name": "rev30",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @rev30/server --filter @rev30/client --parallel dev",
    "dev:client": "pnpm --filter @rev30/client dev",
    "dev:server": "pnpm --filter @rev30/server dev",
    "build": "pnpm -r build",
    "check": "pnpm format:check && pnpm lint:check && pnpm check:deprecated && pnpm typecheck && pnpm test && pnpm build",
    "check:deprecated": "node scripts/check-deprecated-apis.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
