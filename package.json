{
  "name": "rev30",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @rev30/server --filter @rev30/client --parallel dev",
    "dev:client": "pnpm --filter @rev30/client dev",
    "dev:server": "pnpm --filter @rev30/server dev",
    "build": "pnpm -r build",
    "check": "pnpm format:check && pnpm lint:check && pnpm typecheck && pnpm test && pnpm build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.10.0"
}
