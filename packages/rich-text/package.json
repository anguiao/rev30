{
  "name": "@rev30/rich-text",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./server/presets": {
      "types": "./src/server/presets/index.ts",
      "default": "./src/server/presets/index.ts"
    },
    "./vue": {
      "types": "./src/vue/index.ts",
      "default": "./src/vue/index.ts"
    },
    "./vue/presets": {
      "types": "./src/vue/presets/index.ts",
      "default": "./src/vue/presets/index.ts"
    }
  },
  "scripts": {
    "build": "vue-tsc -p tsconfig.app.json --noEmit",
    "typecheck": "vue-tsc -p tsconfig.app.json --noEmit && vue-tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run --pool=threads"
  },
